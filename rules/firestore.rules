rules_version = '2';
// ╔══════════════════════════════════════════════════════════════╗
// ║   الفانوس للتوظيف — قواعد أمان Firestore                   ║
// ╚══════════════════════════════════════════════════════════════╝

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() { return request.auth != null; }
    function isOwner(uid) { return isLoggedIn() && request.auth.uid == uid; }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // يدعم المستخدمين القدامى الذين ليس لديهم role
    function userRole() {
      let r = isLoggedIn() && userData().role != null ? userData().role : 'seeker';
      // ترحيل role: "user" من النظام القديم → seeker
      return r == 'user' ? 'seeker' : r;
    }

    function isAdmin()    { return userRole() == 'admin'; }
    function isOffice()   { return userRole() == 'office'; }
    function isEmployer() { return userRole() == 'employer'; }

    // صاحب وظيفة: مكتب أو صاحب عمل
    function isJobPoster() { return isOffice() || isEmployer() || isAdmin(); }

    // يدعم المستخدمين القدامى الذين ليس لديهم status
    function isActive() {
      return isLoggedIn() && (
        userData().status == 'active' ||
        userData().status == 'approved' ||
        userData().status == null
      );
    }

    // تحقق من حجم الوثيقة (حماية من الحقول الزائدة)
    function validSize(d) { return d.keys().size() <= 30; }

    // ── تحقق من نوع النص وطوله ──
    function validStr(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }

    // ── تحقق من أن الحقول المطلوبة موجودة ──
    function hasFields(d, fields) {
      return fields.toSet().difference(d.keys().toSet()).size() == 0;
    }


    // ══════════════════════════════════════
    // USERS
    // ══════════════════════════════════════
    match /users/{userId} {
      // أي مستخدم مسجّل يقرأ ملفات المكاتب وأصحاب العمل العامة
      // المكاتب وأصحاب العمل يقرؤون ملفات الباحثين المنشورة فقط
      allow read: if isOwner(userId) || isAdmin()
        || (isLoggedIn() && (resource.data.role == 'office' || resource.data.role == 'employer')
            && resource.data.status == 'active')
        || (isJobPoster() && resource.data.role == 'seeker' && resource.data.cvPublished == true);
      allow create: if isOwner(userId) && validSize(request.resource.data)
        && hasFields(request.resource.data, ['name', 'email', 'role'])
        && validStr(request.resource.data.name, 2, 80)
        && validStr(request.resource.data.email, 5, 120);
      allow update: if isAdmin()
        || (isOwner(userId) && validSize(request.resource.data)
            && (resource.data.role == null || request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════
    // JOBS
    // ══════════════════════════════════════
    match /jobs/{jobId} {
      allow read: if resource.data.status == 'active'
        || isAdmin()
        || (isLoggedIn() && resource.data.postedBy == request.auth.uid);

      allow create: if isAdmin()
        || (isJobPoster() && isActive()
            && request.resource.data.postedBy == request.auth.uid
            && validSize(request.resource.data)
            && hasFields(request.resource.data, ['title', 'company', 'desc', 'province', 'postedBy', 'postedAt'])
            && validStr(request.resource.data.title,   3, 100)
            && validStr(request.resource.data.company,  2, 100)
            && validStr(request.resource.data.desc,    20, 3000)
            && request.resource.data.status == 'active');

      allow update: if isAdmin()
        || (isLoggedIn() && resource.data.postedBy == request.auth.uid
            && validSize(request.resource.data)
            && request.resource.data.postedBy == resource.data.postedBy);

      allow delete: if isAdmin()
        || (isLoggedIn() && resource.data.postedBy == request.auth.uid);
    }


    // ══════════════════════════════════════
    // APPLICATIONS — مع Rate Limiting
    // ══════════════════════════════════════
    match /applications/{appId} {
      // المتقدم يرى طلبه، الأدمن يرى الكل، المكتب يرى ترشيحاته، صاحب الوظيفة يرى طلبات وظيفته
      allow read: if isAdmin()
        || (isLoggedIn() && resource.data.applicantId == request.auth.uid)
        || (isOffice() && resource.data.referredBy == request.auth.uid)
        || (isJobPoster()
            && get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.postedBy == request.auth.uid);

      allow create: if isLoggedIn() && isActive()
        && validSize(request.resource.data)
        && hasFields(request.resource.data, ['jobId', 'name', 'phone', 'email', 'cover', 'status'])
        && validStr(request.resource.data.name,  2, 80)
        && validStr(request.resource.data.phone,  9, 20)
        && validStr(request.resource.data.email,  5, 120)
        && request.resource.data.status == 'pending'
        && (
          // باحث يتقدم بنفسه
          (request.resource.data.applicantId == request.auth.uid
           && validStr(request.resource.data.cover, 30, 3000))
          // مكتب يرشّح موظفاً — applicantId يكون 'ref_...' وليس UID
          || (isOffice()
              && request.resource.data.isReferral == true
              && request.resource.data.referredBy == request.auth.uid
              && validStr(request.resource.data.cover, 1, 3000))
        );

      // صاحب الوظيفة (مكتب أو صاحب عمل) يستطيع تحديث حالة الطلب
      allow update: if isAdmin()
        || (isJobPoster()
            && get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.postedBy == request.auth.uid
            && request.resource.data.jobId == resource.data.jobId);

      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════
    // CVS — سيرة الباحث / ملف الشركة
    // ══════════════════════════════════════
    match /cvs/{cvId} {
      // الأدمن يرى الكل
      // المستخدم يرى ملفه فقط
      // المكاتب وأصحاب العمل يرون سير الباحثين (type=resume) لا ملفات الشركات (type=company)
      allow read: if isAdmin()
        || (isLoggedIn() && resource.data.userId == request.auth.uid)
        || (isJobPoster() && resource.data.type != 'company');
      allow create: if isLoggedIn() && isActive()
        && request.resource.data.userId == request.auth.uid
        && validSize(request.resource.data);
      allow update: if isLoggedIn()
        && resource.data.userId == request.auth.uid
        && validSize(request.resource.data);
      allow delete: if isAdmin()
        || (isLoggedIn() && resource.data.userId == request.auth.uid);
    }


    // ══════════════════════════════════════
    // CONFIG
    // ══════════════════════════════════════
    match /config/{docId} {
      // مسجّل فقط — يمنع قراءة مفاتيح API (imgbb, telegram, emailjs...) من الخارج
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }


    // ══════════════════════════════════════
    // NOTIFICATIONS
    // ══════════════════════════════════════
    match /notifications/{notifId} {
      allow read, update, delete: if isLoggedIn()
        && resource.data.userId == request.auth.uid;
      // المكاتب وأصحاب العمل والأدمن يستطيعون إنشاء إشعارات للمتقدمين
      allow create: if isLoggedIn() && isActive()
        && validSize(request.resource.data)
        && hasFields(request.resource.data, ['userId', 'type', 'title', 'body'])
        && isJobPoster();
    }


    // ══════════════════════════════════════
    // SAVED JOBS
    // ══════════════════════════════════════
    match /savedJobs/{saveId} {
      allow read, write: if isLoggedIn()
        && request.auth.uid == saveId.split('_')[0];
    }


    // ══════════════════════════════════════
    // INTERVIEWS
    // ══════════════════════════════════════
    match /interviews/{intId} {
      allow read: if isAdmin()
        || (isLoggedIn() && resource.data.userId == request.auth.uid);
      allow create: if isLoggedIn() && isActive()
        && request.resource.data.userId == request.auth.uid
        && validSize(request.resource.data);
      allow update: if isLoggedIn()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin()
        || (isLoggedIn() && resource.data.userId == request.auth.uid);
    }


    // ══════════════════════════════════════
    // MESSAGES
    // ══════════════════════════════════════
    match /messages/{msgId} {
      allow read: if isLoggedIn()
        && (resource.data.from == request.auth.uid
            || resource.data.to == request.auth.uid
            || isAdmin());
      allow create: if isLoggedIn() && isActive()
        && request.resource.data.from == request.auth.uid
        && hasFields(request.resource.data, ['from', 'to', 'body'])
        && validStr(request.resource.data.body, 1, 2000);
      allow update: if isLoggedIn()
        && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════
    // REPORTS
    // ══════════════════════════════════════
    match /reports/{reportId} {
      allow create: if isLoggedIn() && isActive()
        && request.resource.data.reportedBy == request.auth.uid
        && hasFields(request.resource.data, ['reportedBy', 'targetId', 'reason'])
        && validStr(request.resource.data.reason, 5, 500);
      allow read, update, delete: if isAdmin();
    }


    // ══════════════════════════════════════
    // BOOKINGS — الحجوزات الحصرية (مكاتب التوظيف فقط)
    // ══════════════════════════════════════
    match /bookings/{bookingId} {
      allow read: if isLoggedIn()
        && (resource.data.officeId == request.auth.uid
            || resource.data.candidateId == request.auth.uid
            || isAdmin());
      allow create: if isOffice() && isActive()
        && request.resource.data.officeId == request.auth.uid
        && validSize(request.resource.data)
        && hasFields(request.resource.data, ['officeId', 'candidateId', 'bookedAt', 'expiresAt', 'status'])
        && request.resource.data.status == 'active';
      allow update: if isAdmin()
        || (isOffice() && resource.data.officeId == request.auth.uid
            && request.resource.data.officeId    == resource.data.officeId
            && request.resource.data.candidateId == resource.data.candidateId);
      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════
    // RATINGS — تقييمات المكاتب وأصحاب العمل
    // ══════════════════════════════════════
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isLoggedIn() && isActive()
        && request.resource.data.userId == request.auth.uid
        && validSize(request.resource.data)
        && hasFields(request.resource.data, ['officeId', 'userId', 'rating'])
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }


    // ══════════════════════════════════════
    // QUIZ RESULTS — نتائج الاختبارات الذكية
    // ══════════════════════════════════════
    match /quizResults/{resultId} {
      // صاحب الوظيفة يرى نتائج متقدميه
      allow read: if isAdmin()
        || (isLoggedIn() && resource.data.applicantId == request.auth.uid)
        || (isJobPoster()
            && get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.postedBy == request.auth.uid);
      allow create: if isLoggedIn() && isActive()
        && request.resource.data.applicantId == request.auth.uid
        && validSize(request.resource.data)
        && hasFields(request.resource.data, ['applicantId', 'jobId', 'score'])
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100;
      allow update: if false;
      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════
    // INVITES — دعوات الأدمن للمستخدمين
    // ══════════════════════════════════════
    match /invites/{email} {
      allow read: if isAdmin() || (isLoggedIn() && request.auth.token.email == email);
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }


    // ══════════════════════════════════════
    // CAMPAIGNS — حملات ظهور أرقام التواصل
    // ══════════════════════════════════════
    match /campaigns/{campId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }


    // ══════════════════════════════════════
    // TELEGRAM QUEUE — وظائف بوت تيليجرام المعلقة
    // ══════════════════════════════════════
    match /telegram_queue/{jobId} {
      // الـ Worker يستخدم anonymous Firebase auth للكتابة
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }


    // ══════════════════════════════════════
    // HIRING CAMPAIGNS — حملات التوظيف الجماعي
    // ══════════════════════════════════════
    match /hiring_campaigns/{campId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }


    // ══════════════════════════════════════
    // BANNERS — الإعلانات والبانرات
    // ══════════════════════════════════════
    match /banners/{bannerId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }


    // ══════════════════════════════════════
    // PAYMENTS — طلبات الاشتراك
    // ══════════════════════════════════════
    match /payments/{payId} {
      allow read: if isAdmin()
        || (isLoggedIn() && resource.data.userId == request.auth.uid);
      allow create: if isLoggedIn() && isActive()
        && request.resource.data.userId == request.auth.uid
        && hasFields(request.resource.data, ['userId', 'plan', 'amount', 'status'])
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }


    // ══════════════════════════════════════
    // MANAGED SEEKERS — باحثون مُدارون من المكاتب
    // ══════════════════════════════════════
    match /managed_seekers/{seekerId} {
      // المكتب يرى ملفاته، أصحاب العمل يرون المنشورة، الأدمن يرى الكل
      allow read: if isAdmin()
        || (isOffice() && resource.data.officeId == request.auth.uid)
        || (isJobPoster() && resource.data.published == true);
      allow create: if isAdmin()
        || (isOffice() && isActive()
            && request.resource.data.officeId == request.auth.uid
            && validSize(request.resource.data)
            && hasFields(request.resource.data, ['name', 'phone', 'officeId']));
      allow update: if isAdmin()
        || (isOffice() && resource.data.officeId == request.auth.uid
            && validSize(request.resource.data));
      allow delete: if isAdmin()
        || (isOffice() && resource.data.officeId == request.auth.uid);
    }


    // منع أي وصول غير محدد
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
